<footer class="store-footer" style="background: var(--footer-bg); color: var(--footer-text);">
  <div aria-label="footer" class="store-footer__inner">
    <div class="container grid grid-col-1 lg:grid-cols-6 gap-8 lg:gap-6 py-14">

      {# --- العمود الأول: اسم المتجر + الوصف + سوشيال --- #}
      <div class="lg:col-span-2 rtl:lg:pl-16 ltr:lg:pr-16">
        <a href="{{ link('/') }}" class="inline-block mb-4">
          <span style="font-size:26px; font-weight:800; color:#fff; letter-spacing:-0.5px;">
            دي<span style="color: var(--color-primary);">مو</span>
          </span>
        </a>

        <p style="color: var(--footer-text); font-size:14px; line-height:1.8; margin-bottom:20px; max-width:260px;">
          متجرك الأول للمنتجات الرقمية عالية الجودة — كورسات، قوالب، وبرامج.
        </p>

        {# أيقونات مميزات رقمية #}
        <div style="display:flex; gap:10px; flex-wrap:wrap; margin-bottom:20px;">
          <span style="background:rgba(139,114,240,0.12); border:1px solid var(--color-primary); color:var(--color-primary); padding:5px 12px; border-radius:20px; font-size:12px; font-weight:600;">⚡ تسليم فوري</span>
          <span style="background:rgba(139,114,240,0.12); border:1px solid var(--color-primary); color:var(--color-primary); padding:5px 12px; border-radius:20px; font-size:12px; font-weight:600;">🔒 آمان تام</span>
          <span style="background:rgba(139,114,240,0.12); border:1px solid var(--color-primary); color:var(--color-primary); padding:5px 12px; border-radius:20px; font-size:12px; font-weight:600;">📦 منتجات رقمية</span>
        </div>

        <div class="hidden lg:block">
          <salla-social class="block mb-4"></salla-social>
        </div>

        <div class="flex gap-4 mt-4">
          <salla-trust-badges dark></salla-trust-badges>
          {% if store.settings.tax.number %}
            <div class="flex rtl:space-x-reverse space-x-2 items-end">
              {% if store.settings.tax.certificate %}
                <a class="load-img-onclick" data-modal-id="modal-value-tax" href="#/">
                  <img width="40" height="50" src="{{'images/tax.png' | cdn(70,70)}}" loading="lazy" class="w-10 rounded-sm hover:opacity-80 transition-opacity" alt="value added tax">
                </a>
              {% endif %}
              <div>
                <p style="font-size:12px; color:var(--footer-text-muted); margin-bottom:2px;">{{ trans('common.elements.tax_number') }}</p>
                <b style="font-size:12px; color:var(--footer-text);">{{ store.settings.tax.number }}</b>
              </div>
            </div>
            {% if store.settings.tax.certificate %}
              <salla-modal sub-title-first sub-title="{{ trans('common.elements.tax_number') }}" modal-title="{{ store.settings.tax.number }}" id="modal-value-tax">
                <div class="flex justify-center max-w-full">
                  <img class="w-full" loading="lazy" data-src="{{ store.settings.tax.certificate }}" alt="{{ store.settings.tax.number }}"/>
                </div>
              </salla-modal>
            {% endif %}
          {% endif %}
        </div>
      </div>

      {# --- العمود الثاني: روابط الصفحات --- #}
      <div>
        <h4 style="color:#fff; font-weight:700; font-size:15px; margin-bottom:16px; padding-bottom:10px; border-bottom:1px solid rgba(255,255,255,0.08);">
          روابط سريعة
        </h4>
        <salla-menu source="footer"></salla-menu>
      </div>

      {# --- العمود الثالث: تواصل معنا --- #}
      <div>
        <h4 style="color:#fff; font-weight:700; font-size:15px; margin-bottom:16px; padding-bottom:10px; border-bottom:1px solid rgba(255,255,255,0.08);">
          تواصل معنا
        </h4>
        <salla-contacts></salla-contacts>
        <div class="lg:hidden mt-4">
          <salla-social></salla-social>
        </div>
      </div>

      {# --- العمود الرابع: تطبيقات + مزايا --- #}
      <div class="lg:col-span-2 rtl:lg:pr-16 ltr:lg:pl-16">
        <h4 style="color:#fff; font-weight:700; font-size:15px; margin-bottom:16px; padding-bottom:10px; border-bottom:1px solid rgba(255,255,255,0.08);">
          حمّل التطبيق
        </h4>
        <salla-apps-icons></salla-apps-icons>
      </div>

    </div>
  </div>

  {# --- Footer Bottom --- #}
  <div style="border-top:1px solid rgba(255,255,255,0.07); padding:16px 0;">
    <div class="container md:flex items-center justify-between text-center">
      <span style="font-size:13px; color:var(--footer-text-muted);">{% hook copyright %}</span>
      <salla-payments style="margin-top:8px;"></salla-payments>
    </div>
  </div>

  <span class="hidden bottom-2 rtl:pl-24 ltr:pr-24 md:grid-cols-3 opacity-40"></span>
</footer>
